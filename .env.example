NODE_ENV=development
PORT=8080

# Database Configuration
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/smart_canteen?schema=public
REDIS_URL=redis://localhost:6379

# JWT Secrets (KEEP THESE SECURE - Change in production)
JWT_ACCESS_SECRET=change-this-access-secret
JWT_REFRESH_SECRET=change-this-refresh-secret
JWT_QR_SECRET=change-this-qr-secret
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=30d

# Application Settings
QR_TTL_MINUTES=20
ORDER_DELAY_MINUTES=20
CORS_ORIGIN=http://localhost:3000,http://localhost:5173
PAYMENT_PROVIDER_MODE=fake

# Razorpay Configuration (KEEP THESE SECURE - Never commit actual keys)
RAZORPAY_KEY_ID=rzp_test_key
RAZORPAY_KEY_SECRET=rzp_test_secret
RAZORPAY_WEBHOOK_SECRET=replace-with-razorpay-webhook-secret

# Cloudinary Configuration
CLOUDINARY_CLOUD_NAME=demo
CLOUDINARY_API_KEY=cloudinary-api-key
CLOUDINARY_API_SECRET=cloudinary-api-secret
CLOUDINARY_FOLDER=smart-canteen

# Service Ports
APP_PORT=8080
FRONTEND_PORT=5173
POSTGRES_PORT=5432
POSTGRES_DB=smart_canteen
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
REDIS_PORT=6379

# Frontend Environment Variables (Vite)
VITE_API_BASE_URL=http://localhost:8080/api
VITE_BACKEND_BASE_URL=http://localhost:8080
VITE_PAYMENT_MODE=razorpay
VITE_ENABLE_QA_TOOLS=true
VITE_RAZORPAY_KEY_ID=rzp_test_key
